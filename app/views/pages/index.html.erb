<%= tag.div class: "board-shell",
            data: {
              controller: "pixi",
              pixi_tilesheet_url_value: image_path("tilesheet_v3.png"),
              pixi_building_placements_value: @building_placements.as_json(only: [:row, :col, :building_key])
            } do %>
  <%= tag.div id: "pixi-canvas", data: { pixi_target: "canvas" } %>

  <div class="board-controls">
    <button type="button"
            class="board-button"
            data-action="pixi#toggleBuildMode"
            data-pixi-target="buildingButton"
            aria-pressed="false">
      Building
    </button>

    <button type="button"
            class="board-button"
            data-action="pixi#toggleRoadMode"
            data-pixi-target="roadButton"
            aria-pressed="false">
      Road
    </button>

    <div class="board-mode" data-pixi-target="modeLabel" aria-live="polite">
      Mode: Pan
    </div>
  </div>
<% end %>
